<Window x:Class="P2P_Chat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P2P Chat" Height="450" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="ChatBox" Grid.Row="0" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBox x:Name="MessageInput" Width="300" Margin="0,0,5,0"/>
            <Button Content="Wyślij" Click="SendButton_Click" Width="60"/>
        </StackPanel>
    </Grid>
</Window>